<view class="page">
  <view class="search-box card">
    <input value="{{query}}" bindinput="onInput" placeholder="Search role or company" />
  </view>

  <view class="results">
    <view class="result card" wx:for="{{filteredRecords}}" wx:key="id">
      <view>
        <text class="role">{{item.role}}</text>
        <text class="muted">{{item.companyName}} / {{item.city}} / {{item.level}}</text>
      </view>
      <text class="total">{{item.totalAnnualCnyText}}</text>
    </view>
  </view>
</view>
