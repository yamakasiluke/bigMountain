.header {
  margin-bottom: 24rpx;
}

.eyebrow,
.title,
.metric text,
.gate text {
  display: block;
}

.eyebrow {
  margin-bottom: 8rpx;
  color: #687386;
  font-size: 22rpx;
  font-weight: 700;
  text-transform: uppercase;
}

.title {
  color: #1d2433;
  font-size: 52rpx;
  font-weight: 800;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.metric {
  min-height: 132rpx;
}

.number {
  margin-bottom: 8rpx;
  color: #125e4a;
  font-size: 44rpx;
  font-weight: 800;
}

.primary {
  margin: 0 0 20rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #125e4a;
}

.gate-title {
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 800;
}
